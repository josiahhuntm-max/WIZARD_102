@using Sandbox;
@using Sandbox.UI;
@using System;
@using System.Linq;
@using WizardGame;
@inherits PanelComponent

<root>
    <div class="crosshair">
        <div class="line horizontal"></div>
        <div class="line vertical"></div>
        <div class="dot"></div>
    </div>

    <div class="hud-bottom">
        <div class="vitals-block">
            <div class="label">Health</div>
            <div class="bar health-bar">
                <div class="fill" style=$"width: {HealthPercent * 100f:F0}%"></div>
            </div>
            <div class="value">@($"{CurrentHealth:F0} / {MaxHealth:F0}")</div>
        </div>

        <div class="vitals-block">
            <div class="label">Mana</div>
            <div class="bar mana-bar">
                <div class="fill" style=$"width: {ManaPercent * 100f:F0}%"></div>
            </div>
            <div class="value">@($"{CurrentMana:F0} / {MaxMana:F0}")</div>
        </div>
    </div>
</root>

@code {
    public float CurrentHealth { get; set; } = 100f;
    public float MaxHealth { get; set; } = 100f;
    public float CurrentMana { get; set; } = 100f;
    public float MaxMana { get; set; } = 100f;

    public float HealthPercent => MaxHealth <= 0f ? 0f : CurrentHealth / MaxHealth;
    public float ManaPercent => MaxMana <= 0f ? 0f : CurrentMana / MaxMana;

    protected override void OnUpdate()
    {
        base.OnUpdate();

        var player = Scene.GetAllComponents<WizardPlayer>().FirstOrDefault( x => !x.IsProxy );
        if ( player is null )
            return;

        var vitals = player.Components.Get<WizardVitals>( FindMode.EverythingInSelfAndDescendants );
        if ( vitals is null )
            return;

        CurrentHealth = vitals.CurrentHealth;
        MaxHealth = vitals.MaxHealth;
        CurrentMana = vitals.CurrentMana;
        MaxMana = vitals.MaxMana;
    }
}
